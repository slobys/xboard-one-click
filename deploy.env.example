# xboard-one-click local config example
# 复制为 deploy.env 后修改，再执行 ./install.sh

# 建议保留 80/443 给 NPM，后续申请证书更方便
NPM_HTTP_PORT=80
NPM_HTTPS_PORT=443

# 这两个更建议按你的习惯自定义
NPM_ADMIN_PORT=20881
XBOARD_PORT=27001

XBOARD_ADMIN_EMAIL=admin@example.com
XBOARD_REPO=https://github.com/cedar2025/Xboard
XBOARD_BRANCH=compose
ENABLE_FIREWALL_OPEN=1
FORCE_XBOARD_INSTALL=0
